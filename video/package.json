{
  "name": "ornet-erp-showcase",
  "version": "1.0.0",
  "description": "Ornet ERP cinematic product showcase built with Remotion",
  "private": true,
  "scripts": {
    "dev": "remotion studio",
    "render": "remotion render OrnetShowcase out/ornet-showcase.mp4",
    "render:upwork": "remotion render OrnetUpwork out/ornet-upwork.mp4",
    "still": "remotion still OrnetShowcase --frame=120 --scale=0.5",
    "build": "remotion bundle",
    "upgrade": "remotion upgrade",
    "lint": "eslint src && tsc"
  },
  "dependencies": {
    "@remotion/cli": "4.0.462",
    "@fontsource/inter": "^5.1.0",
    "@remotion/tailwind-v4": "4.0.462",
    "@remotion/transitions": "4.0.462",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "remotion": "4.0.462",
    "tailwindcss": "4.0.0"
  },
  "devDependencies": {
    "@remotion/eslint-config-flat": "4.0.462",
    "@types/react": "19.2.7",
    "@types/web": "0.0.166",
    "eslint": "9.19.0",
    "prettier": "3.8.1",
    "typescript": "5.9.3"
  },
  "sideEffects": ["*.css"]
}
