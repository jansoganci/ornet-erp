# Copy to .env.local for local development (never commit secrets).

# Required for Supabase (browser client; safe to expose anon key in the built app).
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Optional: Sentry client DSN (public; set in Cloudflare Pages for production error reporting).
# If unset, Sentry stays disabled.
# VITE_SENTRY_DSN=https://...@....ingest.sentry.io/...

# Paraşüt Edge Function secrets.
# Set these with Supabase secrets, not as VITE_* browser variables:
# supabase secrets set PARASUT_BASE_URL=https://api.parasut.com/v4
# supabase secrets set PARASUT_OAUTH_URL=https://api.parasut.com/oauth/token
# supabase secrets set PARASUT_CLIENT_ID=...
# supabase secrets set PARASUT_CLIENT_SECRET=...
# supabase secrets set PARASUT_USERNAME=...
# supabase secrets set PARASUT_PASSWORD=...
# supabase secrets set PARASUT_COMPANY_ID=...
